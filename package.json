{
  "name": "stop-wasting-tokens",
  "version": "3.0.0-alpha.38",
  "description": "Token-disciplined, methodology-first SDLC harness for AI coding agents. Vendor-neutral via Pi runtime — 25+ providers (Anthropic, OpenAI, OpenRouter, Google, Ollama, ...).",
  "license": "MIT",
  "author": "Tiago Serôdio (@yidakee)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swt-labs/stop-wasting-tokens.git"
  },
  "bugs": {
    "url": "https://github.com/swt-labs/stop-wasting-tokens/issues"
  },
  "homepage": "https://github.com/swt-labs/stop-wasting-tokens#readme",
  "keywords": [
    "cli",
    "methodology",
    "agents",
    "ai-coding",
    "vibe-coding",
    "vendor-neutral",
    "pi-coding-agent",
    "anthropic",
    "openai",
    "openrouter",
    "ollama",
    "typescript"
  ],
  "type": "module",
  "bin": {
    "swt": "./dist/cli.mjs"
  },
  "module": "./dist/cli.mjs",
  "types": "./dist/cli.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.mjs"
    }
  },
  "files": [
    "dist",
    "packages/dashboard/dist/client",
    "commands",
    "agents",
    "provider_overlays",
    "references",
    "templates",
    "scripts",
    "config",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=20.18"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm dashboard:client:build && tsup",
    "dashboard:client:build": "pnpm --filter @swt-labs/dashboard run build:client",
    "typecheck": "tsc --build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:regression": "vitest run --config vitest.regression.config.ts",
    "test:chaos": "vitest run test/chaos/",
    "test:provider-matrix": "vitest run test/provider-matrix/",
    "coverage": "vitest run --coverage",
    "docs:gen": "tsx scripts/docs-gen.ts",
    "gen:apply-patch-parser": "tsx scripts/codegen/apply-patch-from-lark.ts --in-place",
    "public-benchmark": "node scripts/public-benchmark.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "release:preflight": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm build && pnpm check:tarball-shape",
    "prepublishOnly": "pnpm build",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "check:offline": "node scripts/check-offline.mjs",
    "check:tarball-shape": "node scripts/check-tarball-shape.mjs",
    "record": "pnpm --filter @swt-labs/test-utils record"
  },
  "dependencies": {
    "@napi-rs/keyring": "1.3.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/node": "^22.7.4",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "@vitest/coverage-v8": "^2.1.3",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.3.3",
    "@swt-labs/artifacts": "workspace:*",
    "@swt-labs/cli": "workspace:*",
    "@swt-labs/core": "workspace:*",
    "@swt-labs/orchestration": "workspace:*",
    "@swt-labs/shared": "workspace:*",
    "tsup": "^8.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3",
    "zod": "^3.23.8"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
