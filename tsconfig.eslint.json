{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "incremental": false,
    "noEmit": true,
    "rootDir": ".",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": [
    "packages/*/src/**/*",
    "packages/*/test/**/*",
    "docs/test/**/*",
    "test/**/*",
    "scripts/**/*.ts",
    "tsup.config.ts",
    "vitest.config.ts",
    "vitest.regression.config.ts",
    "eslint.config.mjs",
    "packages/dashboard/vite.config.ts"
  ],
  "exclude": ["**/dist/**", "**/build/**", "**/coverage/**", "**/node_modules/**"]
}
