{
  "name": "@swt-labs/test-utils",
  "version": "3.0.0-alpha.9",
  "description": "Private test infrastructure for SWT v3: cassette recorder + replayer + format schemas + request normalisation. Never published to npm — `private: true` is the safety net. Cassettes may contain prompt content with sensitive context; the recorder is developer-local-only.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./cassettes": {
      "types": "./src/cassettes/index.ts",
      "import": "./src/cassettes/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --build",
    "record": "node --experimental-strip-types ../../scripts/record-cassette.mjs"
  },
  "dependencies": {
    "@swt-labs/methodology": "workspace:*",
    "@swt-labs/runtime": "workspace:*",
    "@swt-labs/shared": "workspace:*",
    "undici": "^6.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "vitest": "^2.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swt-labs/stop-wasting-tokens.git",
    "directory": "packages/test-utils"
  },
  "author": "Tiago Serôdio (@yidakee)"
}
