# replacements for Claude-Code-specific VBW originals). The porter's cp -n
# preserves these on re-run, but they need to be tracked so they ship with
# the npm tarball and arrive in fresh clones.
!scripts/lib/swt-session-state.sh
!scripts/lib/swt-team-state.sh
!scripts/agent-pid-tracker.sh
!scripts/agent-start.sh
!scripts/agent-stop.sh
!scripts/agent-spawn-guard.sh
!scripts/clean-stale-teams.sh
