!scripts/lease-lock.sh
!scripts/hook-wrapper.sh
!scripts/cache-nuke.sh
!scripts/install-hooks.sh
!scripts/ensure-plugin-root-link.sh
!scripts/compaction-instructions.sh
!scripts/post-compact.sh
!scripts/lib/swt-cache-key.sh
!scripts/lib/swt-config-root.sh
!scripts/lib/swt-target-root.sh
